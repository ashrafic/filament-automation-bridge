{
    "name": "ashrafic/filament-webhook-bridge",
    "description": "Turn any Eloquent model event into a webhook trigger for Zapier, Make, or n8n — without writing code.",
    "type": "filament-plugin",
    "license": "MIT",
    "keywords": [
        "filament",
        "laravel",
        "webhook",
        "zapier",
        "make",
        "n8n",
        "filament-plugin"
    ],
    "authors": [
        {
            "name": "Ashraf Islam",
            "email": "ashraf@ashrafic.com"
        }
    ],
    "support": {
        "issues": "https://github.com/ashrafic/filament-webhook-bridge/issues",
        "source": "https://github.com/ashrafic/filament-webhook-bridge"
    },
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-webhook-server": "^3.8",
        "spatie/laravel-package-tools": "^1.15"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Ashrafic\\FilamentWebhookBridge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ashrafic\\FilamentWebhookBridge\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ashrafic\\FilamentWebhookBridge\\FilamentWebhookBridgeServiceProvider"
            ],
            "aliases": {
                "WebhookBridge": "Ashrafic\\FilamentWebhookBridge\\Facades\\WebhookBridge"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "pint": "vendor/bin/pint",
        "pint-test": "vendor/bin/pint --test"
    }
}
